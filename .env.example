# ─────────────────────────────────────────────────────────────────────────────
# MĪZAN — environment variables
#
# Local dev:  copy to .env.local and fill in.
# Production: paste each variable into Vercel → Settings → Environment
#             Variables (Production + Preview), then redeploy.
#
# Vite exposes ONLY `VITE_*` variables to the client bundle. Anything
# else (PLAID_*, SUPABASE_SERVICE_ROLE_KEY, CRON_SECRET, etc.) stays
# server-only and is never shipped to the browser.
#
# Run `node scripts/check-env.mjs` to validate at any time.
# ─────────────────────────────────────────────────────────────────────────────


# ── SUPABASE ────────────────────────────────────────────────────────────────
# Auth + per-user state DB. Sign up at supabase.com.
# Required for multi-user mode. Without these, MĪZAN runs as a single-user
# pass-through (no login screen, all state local to the browser).

# Client-side — exposed to the browser bundle. SAFE to ship publicly
# (RLS-enforced; only authenticated users can read their own rows).
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=ey...

# Server-side — bypasses RLS. NEVER expose to the browser. Used by
# lib/handlers.mjs for cross-user lookups (audit log writes, owner-claim,
# etc.). Get from Supabase → Settings → API → Legacy tab → service_role.
SUPABASE_SERVICE_ROLE_KEY=ey...

# Optional — server falls back to VITE_SUPABASE_URL when SUPABASE_URL
# isn't set. Setting both lets you point the server at a different
# project than the browser (rare; mostly for debugging).
# SUPABASE_URL=https://your-project.supabase.co


# ── SNAPTRADE ──────────────────────────────────────────────────────────────
# Unified brokerage aggregation (60+ brokers). Free sandbox tier.
# Sign up at snaptrade.com/developers.

# Client ID is shipped to the browser via the legacy VITE_ prefix so the
# server-side and dev-script code can read either name.
VITE_SNAPTRADE_CLIENT_ID=your-client-id
# Or the canonical server name (server reads both, prefers VITE_ for back-compat):
# SNAPTRADE_CLIENT_ID=your-client-id

# Consumer key is SECRET — only used for HMAC signing on the server.
# Despite the VITE_ prefix (legacy), the server reads it via process.env
# so it stays out of the client bundle. Prefer the non-prefixed name for
# new deployments.
VITE_SNAPTRADE_CONSUMER_KEY=your-consumer-key
# SNAPTRADE_CONSUMER_KEY=your-consumer-key


# ── FINNHUB (market data) ──────────────────────────────────────────────────
# Real-time quotes + company news. Free tier: 60 calls/min.
# Sign up at finnhub.io.
VITE_FINNHUB_KEY=your-finnhub-key


# ── POLYGON (historical OHLC) ──────────────────────────────────────────────
# Used by the backtester. Free tier: 5 calls/min, 2yr history.
# Sign up at polygon.io.
# Server name preferred; VITE_ fallback maintained for legacy installs.
POLYGON_KEY=your-polygon-key
# VITE_POLYGON_KEY=your-polygon-key


# ── ANTHROPIC (AI Advisor) ─────────────────────────────────────────────────
# Powers the Sharia-aware AI advisor (Claude Sonnet 4). Pay-as-you-go,
# ~$0.01/message. Get a key at console.anthropic.com.
ANTHROPIC_KEY=sk-ant-api03-...
# VITE_ANTHROPIC_KEY=sk-ant-api03-...   # legacy alias, still read


# ── PLAID (bank aggregation) ───────────────────────────────────────────────
# Connect to bank checking/savings/credit accounts. Sandbox is free; production
# requires Plaid to approve your app. Sign up at dashboard.plaid.com.
# All Plaid values are server-only — never exposed to the browser.
PLAID_CLIENT_ID=your-plaid-client-id
PLAID_SECRET=your-plaid-secret
PLAID_ENV=sandbox            # sandbox | development | production


# ── ADMIN ──────────────────────────────────────────────────────────────────
# Email of the owner account. Inherits the legacy mizan_primary SnapTrade
# userSecret on first sign-in so brokerage connections that existed before
# multi-user support shipped come along to the new auth flow.

# Server-side (used by handlers.mjs to match against the Supabase JWT email).
OWNER_EMAIL=you@example.com

# Client-side (used by src/lib/auth.jsx to decide isRoot on the browser
# for UI gating like the API-keys settings panel). Should match OWNER_EMAIL.
VITE_OWNER_EMAIL=you@example.com


# ── CRON ──────────────────────────────────────────────────────────────────
# Shared secret Vercel attaches as `Authorization: Bearer ${CRON_SECRET}`
# when invoking the scheduled /api/cron/sync route. If unset, the cron
# endpoint is UNPROTECTED — anyone who knows the URL can trigger a full
# multi-user SnapTrade sync. Generate with: `openssl rand -hex 32`
CRON_SECRET=set-a-32-byte-random-hex-string-here


# ── ALERTS (Resend) ───────────────────────────────────────────────────────
# Email delivery for the four anomaly detectors (brute-force, SnapTrade
# 5xx spike, cron staleness, new-device sign-in). Get a free key at
# resend.com (3000 emails/mo). When unset, alerts still write to
# audit_log — only the email step is skipped.
RESEND_API_KEY=re_...

# From: header for alert emails. Must be on a domain you've verified in
# the Resend dashboard. Defaults to alerts@mizan.app if unset.
# ALERT_FROM=alerts@your-domain.com


# ── LOCAL DEV ONLY ────────────────────────────────────────────────────────
# Port for the unified dev server (Vite middleware + API). Defaults to 3000.
# PORT=3000

# NODE_ENV is set by Vercel automatically in production. Don't override here.
# NODE_ENV=development
